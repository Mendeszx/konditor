# Copie para .env e ajuste conforme necessário: cp .env.example .env
# O docker compose carrega este arquivo automaticamente.

# ─── Banco de dados ──────────────────────────────────────────────────────────
DB_USER=postgres
DB_PASS=postgres
DB_PORT=5432

# ─── Aplicação ───────────────────────────────────────────────────────────────
APP_PORT=8080
# validate = valida o schema (recomendado). O schema já é aplicado pelo Postgres.
DDL_AUTO=validate

# ─── Segurança ───────────────────────────────────────────────────────────────
# Client ID do Google OAuth (troque pelo seu para login funcionar de verdade).
GOOGLE_CLIENT_ID=1045651153478-4379bpb4fepqg0gvlg4goktic09vl883.apps.googleusercontent.com
# Segredo de assinatura do JWT — MUDE em produção. Mínimo 32 caracteres.
JWT_SECRET=dev-secret-change-me-please-min-32-chars!
JWT_EXPIRATION_SECONDS=3600
JWT_REFRESH_EXPIRATION_SECONDS=2592000
# false apenas em dev local (HTTP). Sempre true em produção (HTTPS).
COOKIE_SECURE=false
# Origens permitidas pelo CORS (separadas por vírgula). Nunca use * em produção.
CORS_ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
